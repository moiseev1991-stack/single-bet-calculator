# ── Required ──────────────────────────────────────────────────────────────────
# Your production domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=Single Bet Calculator

# ── Analytics (optional) ──────────────────────────────────────────────────────
# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Google Search Console (optional) ─────────────────────────────────────────
# Verification code from Search Console > Settings > Ownership verification
GOOGLE_SITE_VERIFICATION=your-verification-code

# ── Contact form (optional) ───────────────────────────────────────────────────
# Register at https://formspree.io — copy the form ID from your dashboard
NEXT_PUBLIC_FORMSPREE_ID=your-form-id
